# =============================================================================
# ConfigBuddy CMDB v2.0 - PRODUCTION Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production files to version control
# USE A SECRETS MANAGER (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault)
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
API_PORT=3000
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
# CRITICAL: Generate strong, unique secrets
# Use: openssl rand -base64 64
# Store in secrets manager, not in .env file
JWT_SECRET=REPLACE_WITH_64_CHAR_SECRET_FROM_SECRETS_MANAGER
JWT_EXPIRATION=24h
API_KEY=REPLACE_WITH_32_CHAR_SECRET_FROM_SECRETS_MANAGER
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_SECRET_FROM_SECRETS_MANAGER

# Internal service bypass for service-to-service calls
RATE_LIMIT_BYPASS_SECRET=REPLACE_WITH_32_CHAR_SECRET_FROM_SECRETS_MANAGER

# -----------------------------------------------------------------------------
# SSL/TLS Configuration
# -----------------------------------------------------------------------------
# CRITICAL: SSL MUST be enabled in production
SSL_ENABLED=true

# Web UI (Nginx) SSL Configuration
NGINX_SSL_ENABLED=true
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/key.pem
NGINX_SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem
NGINX_SSL_DHPARAM_PATH=/etc/nginx/ssl/dhparam.pem

# HSTS Configuration (enforce HTTPS)
NGINX_HSTS_MAX_AGE=31536000
NGINX_HSTS_INCLUDE_SUBDOMAINS=true
NGINX_HSTS_PRELOAD=true

# -----------------------------------------------------------------------------
# Neo4j Graph Database
# -----------------------------------------------------------------------------
# Use neo4j+s:// for SSL connections
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FROM_SECRETS_MANAGER
NEO4J_DATABASE=cmdb
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_TIMEOUT=30000

# Neo4j SSL/TLS Configuration (REQUIRED in production)
NEO4J_SSL_ENABLED=true
NEO4J_BOLT_TLS_LEVEL=REQUIRED
NEO4J_HTTPS_ENABLED=true
NEO4J_ENCRYPTION=true
NEO4J_SSL_TRUST_STRATEGY=TRUST_SYSTEM_CA_SIGNED_CERTIFICATES
NEO4J_SSL_CLIENT_AUTH=NONE
NEO4J_SSL_CERT_PATH=/ssl/neo4j.cert
NEO4J_SSL_KEY_PATH=/ssl/neo4j.key
NEO4J_SSL_CA_PATH=/ssl/ca.crt

# -----------------------------------------------------------------------------
# PostgreSQL (Connector Registry, Credentials, Metadata)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=cmdb
POSTGRES_USER=cmdb_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FROM_SECRETS_MANAGER
POSTGRES_MAX_CONNECTIONS=100

# PostgreSQL SSL/TLS Configuration (REQUIRED in production)
# POSTGRES_SSL_ENABLED: on|off (PostgreSQL config)
# POSTGRES_SSL_MODE: disable|allow|prefer|require|verify-ca|verify-full
#   - prefer: Attempt SSL, fall back to unencrypted (default for development)
#   - require: Require SSL, accept self-signed certificates
#   - verify-full: Require SSL with full certificate validation (recommended for production)
POSTGRES_SSL_ENABLED=on
POSTGRES_SSL_MODE=verify-full
POSTGRES_SSL_CERT_PATH=/ssl/server.crt
POSTGRES_SSL_KEY_PATH=/ssl/server.key
POSTGRES_SSL_CA_PATH=/ssl/ca.crt

# -----------------------------------------------------------------------------
# Redis (Cache & Job Queue)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FROM_SECRETS_MANAGER
REDIS_DB=0
REDIS_KEY_PREFIX=cmdb:

# Redis SSL/TLS Configuration (RECOMMENDED in production)
REDIS_TLS_ENABLED=true
REDIS_TLS_PORT=6380
REDIS_TLS_CERT_PATH=/ssl/redis.crt
REDIS_TLS_KEY_PATH=/ssl/redis.key
REDIS_TLS_CA_PATH=/ssl/ca.crt
REDIS_TLS_AUTH_CLIENTS=yes

# -----------------------------------------------------------------------------
# Kafka (Event Streaming) - Optional
# -----------------------------------------------------------------------------
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=cmdb-production
KAFKA_GROUP_ID=cmdb-production-consumers

# -----------------------------------------------------------------------------
# Discovery Configuration
# -----------------------------------------------------------------------------
DISCOVERY_ENABLED=true
DISCOVERY_DEFAULT_INTERVAL=3600000
DISCOVERY_BATCH_SIZE=100
DISCOVERY_MAX_RETRIES=3
DISCOVERY_RETRY_DELAY=2000

# -----------------------------------------------------------------------------
# ETL Processing
# -----------------------------------------------------------------------------
ETL_ENABLED=true
ETL_BATCH_SIZE=1000
ETL_SYNC_INTERVAL=300000

# -----------------------------------------------------------------------------
# Graph Processing
# -----------------------------------------------------------------------------
GRAPH_RELATIONSHIP_INFERENCE_ENABLED=true
GRAPH_MAX_DEPTH=5
GRAPH_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# AI/ML Features (v2.0)
# -----------------------------------------------------------------------------
AI_ANOMALY_DETECTION_ENABLED=true
AI_DRIFT_DETECTION_ENABLED=true
AI_IMPACT_ANALYSIS_ENABLED=true

# -----------------------------------------------------------------------------
# Rate Limiting (Production-Grade Configuration)
# -----------------------------------------------------------------------------
# CRITICAL: Enable rate limiting to prevent abuse
RATE_LIMIT_ENABLED=true

# Internal service bypass
RATE_LIMIT_BYPASS_HEADER=X-Internal-Service
RATE_LIMIT_BYPASS_SECRET=REPLACE_WITH_SECRET_FROM_SECRETS_MANAGER

# Tier multipliers for API keys
RATE_LIMIT_TIER_STANDARD_MULTIPLIER=5
RATE_LIMIT_TIER_PREMIUM_MULTIPLIER=10
RATE_LIMIT_TIER_ENTERPRISE_MULTIPLIER=20

# REST API rate limits (per hour per IP for anonymous users)
RATE_LIMIT_REST_MAX=5000
RATE_LIMIT_REST_WINDOW_MS=3600000

# GraphQL rate limits (per hour per IP for anonymous users)
RATE_LIMIT_GRAPHQL_MAX=2000
RATE_LIMIT_GRAPHQL_WINDOW_MS=3600000

# Health endpoint rate limits (0 = unlimited)
RATE_LIMIT_HEALTH_MAX=0
RATE_LIMIT_HEALTH_WINDOW_MS=60000

# Authentication endpoint rate limits (prevent brute force)
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=3600000

# Discovery endpoint rate limits (per hour)
RATE_LIMIT_DISCOVERY_MAX=500
RATE_LIMIT_DISCOVERY_WINDOW_MS=3600000

# Admin endpoint rate limits (per hour)
RATE_LIMIT_ADMIN_MAX=500
RATE_LIMIT_ADMIN_WINDOW_MS=3600000

# Rate limit monitoring
RATE_LIMIT_MONITORING_ENABLED=true
RATE_LIMIT_LOG_HITS=true

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=true
TRACING_ENDPOINT=http://jaeger:4318
AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Grafana Dashboard Configuration
# -----------------------------------------------------------------------------
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FROM_SECRETS_MANAGER
GRAFANA_ROOT_URL=https://grafana.configbuddy.example.com
GRAFANA_DOMAIN=grafana.configbuddy.example.com
GRAFANA_DATABASE=grafana
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_ANONYMOUS_ROLE=Viewer

# -----------------------------------------------------------------------------
# Web UI Configuration
# -----------------------------------------------------------------------------
WEB_UI_PORT=80
WEB_UI_API_ENDPOINT=https://api.configbuddy.example.com

# -----------------------------------------------------------------------------
# Database Backup Configuration
# -----------------------------------------------------------------------------
# CRITICAL: Configure backups for disaster recovery
BACKUP_DIR=/var/backups/configbuddy

# Backup log directory
BACKUP_LOG_DIR=/var/log/configbuddy/backups

# Retention policy (adjust based on compliance requirements)
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12

# Cloud storage upload (RECOMMENDED for production)
BACKUP_UPLOAD_ENABLED=true
BACKUP_STORAGE_TYPE=s3

# AWS S3 Configuration (if using S3 for backup uploads)
BACKUP_S3_BUCKET=configbuddy-production-backups
BACKUP_S3_PREFIX=production
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_FROM_SECRETS_MANAGER
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_KEY_FROM_SECRETS_MANAGER
AWS_DEFAULT_REGION=us-east-1

# Azure Blob Storage Configuration (if using Azure for backup uploads)
BACKUP_AZURE_CONTAINER=configbuddy-production-backups
BACKUP_AZURE_PREFIX=production
AZURE_STORAGE_ACCOUNT=REPLACE_WITH_AZURE_ACCOUNT_FROM_SECRETS_MANAGER
AZURE_STORAGE_ACCESS_KEY=REPLACE_WITH_AZURE_KEY_FROM_SECRETS_MANAGER

# Backup notifications (CRITICAL for production)
BACKUP_NOTIFICATION_ENABLED=true
BACKUP_NOTIFICATION_WEBHOOK=https://hooks.slack.com/services/YOUR/PRODUCTION/WEBHOOK

# Backup health check thresholds
BACKUP_MAX_AGE_HOURS=25
BACKUP_MIN_COUNT=3
DISK_USAGE_THRESHOLD=85

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================
# [ ] All passwords are strong and unique (min 32 characters)
# [ ] Secrets stored in secrets manager (AWS/Azure/Vault)
# [ ] SSL certificates obtained from trusted CA (Let's Encrypt)
# [ ] SSL enabled for ALL services (Neo4j, PostgreSQL, Redis, Nginx)
# [ ] DH parameters generated (4096-bit)
# [ ] HSTS enabled with preload
# [ ] Rate limiting enabled
# [ ] Audit logging enabled
# [ ] Backups configured and tested
# [ ] Cloud backup upload enabled
# [ ] Backup notifications configured
# [ ] Monitoring and alerting configured
# [ ] Firewall rules configured
# [ ] Default credentials changed
# [ ] Anonymous access disabled (Grafana)
# [ ] Log level set to 'info' or 'warn' (not 'debug')
# =============================================================================

# =============================================================================
# PRODUCTION PERFORMANCE CHECKLIST
# =============================================================================
# [ ] Database memory configured for workload size
# [ ] Connection pools sized appropriately
# [ ] Indexes created on frequently queried fields
# [ ] Resource limits set (CPU/memory)
# [ ] Auto-scaling configured (if cloud deployment)
# [ ] Load balancer configured (if multi-node)
# [ ] Database replication configured (if HA)
# [ ] Redis Sentinel configured (if HA)
# =============================================================================

# =============================================================================
# SECRETS MANAGER INTEGRATION EXAMPLES
# =============================================================================
# AWS Secrets Manager:
#   export JWT_SECRET=$(aws secretsmanager get-secret-value \
#     --secret-id configbuddy/production/jwt-secret \
#     --query SecretString --output text)
#
# Azure Key Vault:
#   export JWT_SECRET=$(az keyvault secret show \
#     --vault-name configbuddy-prod \
#     --name jwt-secret \
#     --query value --output tsv)
#
# HashiCorp Vault:
#   export JWT_SECRET=$(vault kv get \
#     -field=jwt_secret secret/configbuddy/production)
# =============================================================================
