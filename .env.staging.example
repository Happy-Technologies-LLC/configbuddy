# =============================================================================
# ConfigBuddy CMDB v2.0 - STAGING Environment Configuration
# =============================================================================
# Copy this file to .env.staging and fill in your actual values
# NEVER commit .env.staging files to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=staging
LOG_LEVEL=debug
API_PORT=3000
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
# IMPORTANT: Use different secrets than production
# Generate with: openssl rand -base64 64
JWT_SECRET=your-staging-jwt-secret-different-from-production-minimum-32-chars
JWT_EXPIRATION=24h
API_KEY=your-staging-api-key-different-from-production
ENCRYPTION_KEY=your-staging-encryption-key-different-from-production-minimum-32-chars

# Internal service bypass for service-to-service calls
RATE_LIMIT_BYPASS_SECRET=your-staging-bypass-secret-different-from-production

# -----------------------------------------------------------------------------
# SSL/TLS Configuration
# -----------------------------------------------------------------------------
# SSL optional in staging (recommended for testing SSL config)
SSL_ENABLED=true

# Web UI (Nginx) SSL Configuration
NGINX_SSL_ENABLED=true
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/key.pem
NGINX_SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem
NGINX_SSL_DHPARAM_PATH=/etc/nginx/ssl/dhparam.pem

# HSTS Configuration (shorter duration for staging)
NGINX_HSTS_MAX_AGE=86400
NGINX_HSTS_INCLUDE_SUBDOMAINS=false
NGINX_HSTS_PRELOAD=false

# -----------------------------------------------------------------------------
# Neo4j Graph Database
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-staging-neo4j-password
NEO4J_DATABASE=cmdb_staging
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30000

# Neo4j SSL/TLS Configuration
NEO4J_SSL_ENABLED=true
NEO4J_BOLT_TLS_LEVEL=OPTIONAL
NEO4J_HTTPS_ENABLED=true
NEO4J_SSL_CERT_PATH=/ssl/neo4j.cert
NEO4J_SSL_KEY_PATH=/ssl/neo4j.key
NEO4J_SSL_CA_PATH=/ssl/ca.crt

# -----------------------------------------------------------------------------
# PostgreSQL (Connector Registry, Credentials, Metadata)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=cmdb_staging
POSTGRES_USER=cmdb_staging_user
POSTGRES_PASSWORD=your-staging-postgres-password
POSTGRES_MAX_CONNECTIONS=50

# PostgreSQL SSL/TLS Configuration
POSTGRES_SSL_ENABLED=on
POSTGRES_SSL_MODE=prefer
POSTGRES_SSL_CERT_PATH=/ssl/server.crt
POSTGRES_SSL_KEY_PATH=/ssl/server.key
POSTGRES_SSL_CA_PATH=/ssl/ca.crt

# -----------------------------------------------------------------------------
# Redis (Cache & Job Queue)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-staging-redis-password
REDIS_DB=1
REDIS_KEY_PREFIX=cmdb:staging:

# Redis SSL/TLS Configuration
REDIS_TLS_ENABLED=false
REDIS_TLS_PORT=0
REDIS_TLS_CERT_PATH=/ssl/redis.crt
REDIS_TLS_KEY_PATH=/ssl/redis.key
REDIS_TLS_CA_PATH=/ssl/ca.crt
REDIS_TLS_AUTH_CLIENTS=no

# -----------------------------------------------------------------------------
# Kafka (Event Streaming) - Optional
# -----------------------------------------------------------------------------
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cmdb-staging
KAFKA_GROUP_ID=cmdb-staging-consumers

# -----------------------------------------------------------------------------
# Discovery Configuration
# -----------------------------------------------------------------------------
DISCOVERY_ENABLED=true
DISCOVERY_DEFAULT_INTERVAL=3600000
DISCOVERY_BATCH_SIZE=100
DISCOVERY_MAX_RETRIES=3
DISCOVERY_RETRY_DELAY=2000

# -----------------------------------------------------------------------------
# ETL Processing
# -----------------------------------------------------------------------------
ETL_ENABLED=true
ETL_BATCH_SIZE=1000
ETL_SYNC_INTERVAL=300000

# -----------------------------------------------------------------------------
# Graph Processing
# -----------------------------------------------------------------------------
GRAPH_RELATIONSHIP_INFERENCE_ENABLED=true
GRAPH_MAX_DEPTH=5
GRAPH_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# AI/ML Features (v2.0)
# -----------------------------------------------------------------------------
AI_ANOMALY_DETECTION_ENABLED=true
AI_DRIFT_DETECTION_ENABLED=true
AI_IMPACT_ANALYSIS_ENABLED=true

# -----------------------------------------------------------------------------
# Rate Limiting (Relaxed for staging)
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true

# Internal service bypass
RATE_LIMIT_BYPASS_HEADER=X-Internal-Service
RATE_LIMIT_BYPASS_SECRET=your-internal-service-secret-staging

# Tier multipliers
RATE_LIMIT_TIER_STANDARD_MULTIPLIER=5
RATE_LIMIT_TIER_PREMIUM_MULTIPLIER=10
RATE_LIMIT_TIER_ENTERPRISE_MULTIPLIER=20

# REST API rate limits (relaxed for testing)
RATE_LIMIT_REST_MAX=10000
RATE_LIMIT_REST_WINDOW_MS=3600000

# GraphQL rate limits
RATE_LIMIT_GRAPHQL_MAX=5000
RATE_LIMIT_GRAPHQL_WINDOW_MS=3600000

# Health endpoint (unlimited)
RATE_LIMIT_HEALTH_MAX=0
RATE_LIMIT_HEALTH_WINDOW_MS=60000

# Authentication endpoint
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=3600000

# Discovery endpoint
RATE_LIMIT_DISCOVERY_MAX=500
RATE_LIMIT_DISCOVERY_WINDOW_MS=3600000

# Admin endpoint
RATE_LIMIT_ADMIN_MAX=1000
RATE_LIMIT_ADMIN_WINDOW_MS=3600000

# Rate limit monitoring
RATE_LIMIT_MONITORING_ENABLED=true
RATE_LIMIT_LOG_HITS=true

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=true
TRACING_ENDPOINT=http://localhost:4318
AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Grafana Dashboard Configuration
# -----------------------------------------------------------------------------
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-staging-grafana-password
GRAFANA_ROOT_URL=http://staging.configbuddy.example.com:3001
GRAFANA_DOMAIN=staging.configbuddy.example.com
GRAFANA_DATABASE=grafana_staging
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_ANONYMOUS_ROLE=Viewer

# -----------------------------------------------------------------------------
# Web UI Configuration
# -----------------------------------------------------------------------------
WEB_UI_PORT=3001
WEB_UI_API_ENDPOINT=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_DIR=/var/backups/configbuddy-staging

# Backup log directory
BACKUP_LOG_DIR=/var/log/configbuddy/backups-staging

# Retention policy (shorter for staging)
BACKUP_RETENTION_DAILY=3
BACKUP_RETENTION_WEEKLY=2
BACKUP_RETENTION_MONTHLY=6

# Cloud storage upload (optional for staging)
BACKUP_UPLOAD_ENABLED=false
BACKUP_STORAGE_TYPE=s3

# AWS S3 Configuration
BACKUP_S3_BUCKET=configbuddy-staging-backups
BACKUP_S3_PREFIX=staging
AWS_ACCESS_KEY_ID=your-staging-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-staging-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Azure Blob Storage Configuration
BACKUP_AZURE_CONTAINER=configbuddy-staging-backups
BACKUP_AZURE_PREFIX=staging
AZURE_STORAGE_ACCOUNT=your-staging-storage-account
AZURE_STORAGE_ACCESS_KEY=your-staging-storage-access-key

# Backup notifications
BACKUP_NOTIFICATION_ENABLED=true
BACKUP_NOTIFICATION_WEBHOOK=https://hooks.slack.com/services/YOUR/STAGING/WEBHOOK

# Backup health check thresholds
BACKUP_MAX_AGE_HOURS=48
BACKUP_MIN_COUNT=2
DISK_USAGE_THRESHOLD=85

# =============================================================================
# STAGING ENVIRONMENT NOTES
# =============================================================================
# - Use staging-specific credentials (different from production)
# - SSL recommended for testing SSL configuration
# - Rate limits relaxed for testing
# - Backup retention reduced (save storage costs)
# - Tracing enabled for debugging
# - Anonymous Grafana access disabled
# - Cloud backup optional (cost savings)
# =============================================================================
