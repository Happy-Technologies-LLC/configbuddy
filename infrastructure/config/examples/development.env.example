# ConfigBuddy v3.0 Development Environment Configuration
# Copy this file to /.env in the project root and adjust values as needed

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
LOG_LEVEL=debug
API_PORT=3000
API_HOST=0.0.0.0

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Generate secure keys: openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-change-in-production-minimum-32-characters-required
JWT_EXPIRATION=24h
ENCRYPTION_KEY=dev-encryption-key-change-in-production-minimum-32-chars

# API Security
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000

# =============================================================================
# NEO4J GRAPH DATABASE
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=cmdb
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60000

# =============================================================================
# POSTGRESQL (Connector Registry, Credentials, Metadata)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=cmdb_datamart
POSTGRES_USER=cmdb_user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_IDLE_TIMEOUT_MS=10000
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# =============================================================================
# REDIS (Cache & Job Queue)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000

# =============================================================================
# DISCOVERY CONFIGURATION
# =============================================================================
DISCOVERY_ENABLED=true
DISCOVERY_DEFAULT_INTERVAL=3600000
DISCOVERY_BATCH_SIZE=50
DISCOVERY_CONCURRENCY=2
DISCOVERY_TIMEOUT=300000

# =============================================================================
# v3.0 UNIFIED FRAMEWORK
# =============================================================================
V3_UNIFIED_FRAMEWORK_ENABLED=true
ITIL_ENABLED=true
TBM_ENABLED=true
BSM_ENABLED=true
UNIFIED_VIEW_CACHE_TTL=300

# =============================================================================
# ITIL SERVICE MANAGER
# =============================================================================
ITIL_PRIORITY_CALCULATION_ENABLED=true
ITIL_CHANGE_RISK_ENABLED=true
ITIL_BASELINE_MANAGEMENT_ENABLED=true
ITIL_CAB_APPROVAL_THRESHOLD=50
ITIL_EXECUTIVE_APPROVAL_THRESHOLD=75
ITIL_P1_RESPONSE_MINUTES=15
ITIL_P1_RESOLUTION_MINUTES=240
ITIL_DRIFT_CHECK_ENABLED=true
ITIL_DRIFT_SEVERITY_THRESHOLD=30

# =============================================================================
# TBM COST ENGINE
# =============================================================================
TBM_COST_ALLOCATION_ENABLED=true
TBM_DEPRECIATION_METHOD=straight_line
TBM_DEFAULT_DEPRECIATION_YEARS=3
TBM_CLOUD_SYNC_ENABLED=false
TBM_CLOUD_SYNC_INTERVAL=86400000
TBM_AWS_COST_EXPLORER_ENABLED=false
TBM_AZURE_COST_MGMT_ENABLED=false
TBM_GCP_BILLING_ENABLED=false
TBM_LICENSE_TRACKING_ENABLED=true
TBM_LICENSE_RENEWAL_ALERT_DAYS=30
TBM_BUDGET_VARIANCE_THRESHOLD=10
TBM_COST_ANOMALY_ENABLED=false

# =============================================================================
# BSM IMPACT ENGINE
# =============================================================================
BSM_ENABLED=true
BSM_BATCH_SIZE=50
BSM_MAX_BLAST_RADIUS_HOPS=5
BSM_TIER_0_THRESHOLD=1000000
BSM_TIER_1_THRESHOLD=500000
BSM_TIER_2_THRESHOLD=100000
BSM_TIER_3_THRESHOLD=10000
BSM_WEIGHT_REVENUE=0.40
BSM_WEIGHT_CUSTOMERS=0.25
BSM_WEIGHT_TRANSACTIONS=0.15
BSM_WEIGHT_COMPLIANCE=0.10
BSM_WEIGHT_USERS=0.10
BSM_RISK_INCIDENT_WEIGHT=0.30
BSM_RISK_CHANGE_WEIGHT=0.25
BSM_RISK_AVAILABILITY_WEIGHT=0.25
BSM_RISK_COMPLIANCE_WEIGHT=0.10
BSM_RISK_AUDIT_WEIGHT=0.10
BSM_BLAST_RADIUS_TIMEOUT=300000
BSM_GRAPH_TRAVERSAL_CACHE_TTL=300

# =============================================================================
# AI/ML ENGINE
# =============================================================================
# Anomaly Detection
AI_ANOMALY_DETECTION_ENABLED=false
AI_ANOMALY_SENSITIVITY=medium
AI_ANOMALY_MIN_CONFIDENCE=70
AI_ANOMALY_CHECK_INTERVAL=60
AI_ANOMALY_LOOKBACK_DAYS=30

# Configuration Drift Detection
AI_DRIFT_DETECTION_ENABLED=true
AI_DRIFT_SEVERITY_THRESHOLD=30
AI_DRIFT_AUTO_BASELINE_ENABLED=true

# Impact Prediction
AI_IMPACT_PREDICTION_ENABLED=true
AI_IMPACT_MAX_BLAST_RADIUS=100
AI_IMPACT_CRITICALITY_CACHE_TTL=604800

# =============================================================================
# AI DISCOVERY (Agentic AI)
# =============================================================================
AI_DISCOVERY_ENABLED=false
AI_DISCOVERY_LLM_PROVIDER=anthropic
AI_DISCOVERY_MODEL=claude-3-5-sonnet-20241022

# LLM API Keys (set if AI Discovery enabled)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI Discovery Budgets (development - conservative limits)
AI_DISCOVERY_MAX_COST_PER_SESSION=0.50
AI_DISCOVERY_MONTHLY_BUDGET=10.00
AI_DISCOVERY_COST_WARNING_THRESHOLD=0.80
AI_DISCOVERY_COST_ALERT_THRESHOLD=0.95

# AI Discovery Performance
AI_DISCOVERY_MAX_ITERATIONS=5
AI_DISCOVERY_TIMEOUT=300000
AI_DISCOVERY_CONCURRENCY=1

# =============================================================================
# EVENT STREAMING (KAFKA) - DISABLED FOR DEVELOPMENT
# =============================================================================
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cmdb-dev
KAFKA_GROUP_ID=cmdb-consumers-dev
KAFKA_CONNECTION_TIMEOUT=30000
KAFKA_REQUEST_TIMEOUT=30000
KAFKA_SSL_ENABLED=false
KAFKA_SASL_ENABLED=false
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_REPLICATION_FACTOR=1
KAFKA_PARTITIONS_DEFAULT=3
KAFKA_RETENTION_HOURS=24
KAFKA_COMPRESSION_TYPE=snappy

# =============================================================================
# METABASE BUSINESS INTELLIGENCE - OPTIONAL FOR DEVELOPMENT
# =============================================================================
METABASE_ENABLED=false
METABASE_PORT=3002
METABASE_DATABASE=metabase
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=metabase-dev-password
METABASE_ENCRYPTION_KEY=dev-metabase-encryption-key-32-chars
METABASE_SITE_URL=http://localhost:3002
METABASE_READONLY_USER=metabase_readonly
METABASE_READONLY_PASSWORD=readonly-dev-password
METABASE_AUTO_SYNC_ENABLED=true
METABASE_AUTO_SYNC_SCHEDULE=0 3 * * *

# =============================================================================
# MONITORING & TELEMETRY - MINIMAL FOR DEVELOPMENT
# =============================================================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=false
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
METRICS_INTERVAL=30000
HEALTH_CHECK_INTERVAL=60000

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=7

# =============================================================================
# EMAIL/SMTP - DISABLED FOR DEVELOPMENT
# =============================================================================
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@configbuddy.local

# =============================================================================
# WEB UI
# =============================================================================
WEB_UI_PORT=3001
WEB_UI_API_URL=http://localhost:3000

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_DISCOVERY=false
FEATURE_PATTERN_LEARNING=false
FEATURE_AGENTIC_AI=false
FEATURE_EVENT_STREAMING=false
FEATURE_ADVANCED_ANALYTICS=false

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Enable detailed error messages and stack traces
DEBUG=true
VERBOSE_LOGGING=true

# Development-specific settings
HOT_RELOAD_ENABLED=true
CACHE_ENABLED=false
MOCK_EXTERNAL_APIS=false

# =============================================================================
# NOTES
# =============================================================================
# This configuration is optimized for local development:
# - Minimal resource requirements
# - Fast startup time
# - Detailed logging for debugging
# - Optional services disabled by default (Kafka, Metabase, Monitoring)
# - AI Discovery disabled to avoid API costs
# - Cloud cost sync disabled
#
# To enable optional services, set the corresponding ENABLED flag to true
# and ensure the required infrastructure is running (Docker Compose).
#
# For production configuration, see production.env.example
