# ConfigBuddy v3.0 Production Environment Configuration
# CRITICAL: Review all settings carefully before production deployment
# Store sensitive values in Kubernetes secrets or vault - NEVER commit secrets

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=production
LOG_LEVEL=warn
API_PORT=3000
API_HOST=0.0.0.0

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# CRITICAL: Generate cryptographically strong secrets
# openssl rand -base64 32
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRATION=4h
ENCRYPTION_KEY=${ENCRYPTION_KEY}

# API Security (Strict for production)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
BCRYPT_ROUNDS=12

# Session Management
SESSION_TIMEOUT=3600000
MAX_FAILED_LOGINS=5
LOCKOUT_DURATION=900000

# =============================================================================
# NEO4J GRAPH DATABASE (High Availability Cluster)
# =============================================================================
NEO4J_URI=bolt+routing://neo4j-cluster.internal:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=${NEO4J_PASSWORD}
NEO4J_DATABASE=cmdb
NEO4J_MAX_CONNECTION_POOL_SIZE=200
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60000
NEO4J_MAX_TRANSACTION_RETRY_TIME=30000

# Connection Pool Tuning
NEO4J_CONNECTION_TIMEOUT=30000
NEO4J_MAX_CONNECTION_LIFETIME=3600000

# =============================================================================
# POSTGRESQL (High Availability with Read Replicas)
# =============================================================================
# Primary Database
POSTGRES_HOST=postgres-primary.internal
POSTGRES_PORT=5432
POSTGRES_DATABASE=cmdb_datamart
POSTGRES_USER=cmdb_user
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_IDLE_TIMEOUT_MS=10000
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# Read Replicas (for read-heavy workloads)
POSTGRES_READ_REPLICA_HOSTS=postgres-replica-1.internal:5432,postgres-replica-2.internal:5432
POSTGRES_READ_REPLICA_ENABLED=true

# Connection Pooling (PgBouncer)
POSTGRES_POOLING_ENABLED=true
POSTGRES_POOL_MODE=transaction

# =============================================================================
# REDIS (Sentinel High Availability)
# =============================================================================
REDIS_SENTINEL_ENABLED=true
REDIS_SENTINELS=sentinel-1.internal:26379,sentinel-2.internal:26379,sentinel-3.internal:26379
REDIS_SENTINEL_NAME=cmdb-redis-master
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0
REDIS_MAX_RETRIES=5
REDIS_RETRY_DELAY_MS=1000

# Redis Persistence
REDIS_AOF_ENABLED=true
REDIS_RDB_ENABLED=true

# =============================================================================
# DISCOVERY CONFIGURATION
# =============================================================================
DISCOVERY_ENABLED=true
DISCOVERY_DEFAULT_INTERVAL=3600000
DISCOVERY_BATCH_SIZE=200
DISCOVERY_CONCURRENCY=10
DISCOVERY_TIMEOUT=900000

# Error Handling
DISCOVERY_MAX_RETRIES=3
DISCOVERY_RETRY_DELAY=5000

# =============================================================================
# v3.0 UNIFIED FRAMEWORK
# =============================================================================
V3_UNIFIED_FRAMEWORK_ENABLED=true
ITIL_ENABLED=true
TBM_ENABLED=true
BSM_ENABLED=true
UNIFIED_VIEW_CACHE_TTL=300

# =============================================================================
# ITIL SERVICE MANAGER
# =============================================================================
ITIL_PRIORITY_CALCULATION_ENABLED=true
ITIL_CHANGE_RISK_ENABLED=true
ITIL_BASELINE_MANAGEMENT_ENABLED=true
ITIL_CAB_APPROVAL_THRESHOLD=50
ITIL_EXECUTIVE_APPROVAL_THRESHOLD=75
ITIL_P1_RESPONSE_MINUTES=15
ITIL_P1_RESOLUTION_MINUTES=240
ITIL_DRIFT_CHECK_ENABLED=true
ITIL_DRIFT_SEVERITY_THRESHOLD=30

# ITIL Integration
ITIL_SERVICENOW_INTEGRATION_ENABLED=true
ITIL_JIRA_INTEGRATION_ENABLED=true

# =============================================================================
# TBM COST ENGINE
# =============================================================================
TBM_COST_ALLOCATION_ENABLED=true
TBM_DEPRECIATION_METHOD=straight_line
TBM_DEFAULT_DEPRECIATION_YEARS=3
TBM_CLOUD_SYNC_ENABLED=true
TBM_CLOUD_SYNC_INTERVAL=86400000
TBM_AWS_COST_EXPLORER_ENABLED=true
TBM_AZURE_COST_MGMT_ENABLED=true
TBM_GCP_BILLING_ENABLED=true
TBM_LICENSE_TRACKING_ENABLED=true
TBM_LICENSE_RENEWAL_ALERT_DAYS=30
TBM_BUDGET_VARIANCE_THRESHOLD=10
TBM_COST_ANOMALY_ENABLED=true

# TBM Reporting
TBM_MONTHLY_REPORT_ENABLED=true
TBM_MONTHLY_REPORT_RECIPIENTS=${TBM_REPORT_RECIPIENTS}

# =============================================================================
# BSM IMPACT ENGINE
# =============================================================================
BSM_ENABLED=true
BSM_BATCH_SIZE=100
BSM_MAX_BLAST_RADIUS_HOPS=10
BSM_TIER_0_THRESHOLD=1000000
BSM_TIER_1_THRESHOLD=500000
BSM_TIER_2_THRESHOLD=100000
BSM_TIER_3_THRESHOLD=10000

# BSM Scoring Weights
BSM_WEIGHT_REVENUE=0.40
BSM_WEIGHT_CUSTOMERS=0.25
BSM_WEIGHT_TRANSACTIONS=0.15
BSM_WEIGHT_COMPLIANCE=0.10
BSM_WEIGHT_USERS=0.10

# BSM Risk Assessment Weights
BSM_RISK_INCIDENT_WEIGHT=0.30
BSM_RISK_CHANGE_WEIGHT=0.25
BSM_RISK_AVAILABILITY_WEIGHT=0.25
BSM_RISK_COMPLIANCE_WEIGHT=0.10
BSM_RISK_AUDIT_WEIGHT=0.10

# BSM Performance Settings
BSM_BLAST_RADIUS_TIMEOUT=300000
BSM_GRAPH_TRAVERSAL_CACHE_TTL=300

# =============================================================================
# AI/ML ENGINE
# =============================================================================
# Anomaly Detection
AI_ANOMALY_DETECTION_ENABLED=true
AI_ANOMALY_SENSITIVITY=medium
AI_ANOMALY_MIN_CONFIDENCE=75
AI_ANOMALY_CHECK_INTERVAL=60
AI_ANOMALY_LOOKBACK_DAYS=30

# Configuration Drift Detection
AI_DRIFT_DETECTION_ENABLED=true
AI_DRIFT_SEVERITY_THRESHOLD=30
AI_DRIFT_AUTO_BASELINE_ENABLED=true

# Impact Prediction
AI_IMPACT_PREDICTION_ENABLED=true
AI_IMPACT_MAX_BLAST_RADIUS=200
AI_IMPACT_CRITICALITY_CACHE_TTL=604800

# =============================================================================
# AI DISCOVERY (Agentic AI) - PRODUCTION BUDGET CONTROLS
# =============================================================================
AI_DISCOVERY_ENABLED=true
AI_DISCOVERY_LLM_PROVIDER=anthropic
AI_DISCOVERY_MODEL=claude-3-5-sonnet-20241022

# LLM API Keys (production keys - store in secrets)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}

# AI Discovery Budgets (production - higher limits but controlled)
AI_DISCOVERY_MAX_COST_PER_SESSION=5.00
AI_DISCOVERY_MONTHLY_BUDGET=500.00
AI_DISCOVERY_COST_WARNING_THRESHOLD=0.80
AI_DISCOVERY_COST_ALERT_THRESHOLD=0.90

# AI Discovery Performance
AI_DISCOVERY_MAX_ITERATIONS=15
AI_DISCOVERY_TIMEOUT=600000
AI_DISCOVERY_CONCURRENCY=5

# =============================================================================
# EVENT STREAMING (KAFKA) - PRODUCTION CLUSTER
# =============================================================================
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka-1.internal:9092,kafka-2.internal:9092,kafka-3.internal:9092
KAFKA_CLIENT_ID=cmdb-production
KAFKA_GROUP_ID=cmdb-consumers-production
KAFKA_CONNECTION_TIMEOUT=30000
KAFKA_REQUEST_TIMEOUT=30000

# Kafka Security (REQUIRED for production)
KAFKA_SSL_ENABLED=true
KAFKA_SSL_CA_PATH=/certs/kafka-ca.crt
KAFKA_SSL_CERT_PATH=/certs/kafka-client.crt
KAFKA_SSL_KEY_PATH=/certs/kafka-client.key

# Kafka SASL Authentication (REQUIRED for production)
KAFKA_SASL_ENABLED=true
KAFKA_SASL_MECHANISM=scram-sha-512
KAFKA_SASL_USERNAME=${KAFKA_USERNAME}
KAFKA_SASL_PASSWORD=${KAFKA_PASSWORD}

# Kafka Topic Configuration (Production settings)
KAFKA_AUTO_CREATE_TOPICS=false
KAFKA_REPLICATION_FACTOR=3
KAFKA_PARTITIONS_DEFAULT=12
KAFKA_RETENTION_HOURS=168
KAFKA_COMPRESSION_TYPE=snappy

# Kafka Performance
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=10
KAFKA_CONSUMER_MAX_POLL_RECORDS=500

# =============================================================================
# METABASE BUSINESS INTELLIGENCE
# =============================================================================
METABASE_ENABLED=true
METABASE_PORT=3002
METABASE_DATABASE=metabase
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=${METABASE_DB_PASSWORD}
METABASE_ENCRYPTION_KEY=${METABASE_ENCRYPTION_KEY}
METABASE_SITE_URL=https://bi.configbuddy.com
METABASE_READONLY_USER=metabase_readonly
METABASE_READONLY_PASSWORD=${METABASE_READONLY_PASSWORD}
METABASE_AUTO_SYNC_ENABLED=true
METABASE_AUTO_SYNC_SCHEDULE=0 3 * * *

# Metabase SSO (optional)
METABASE_SSO_ENABLED=false
METABASE_SSO_PROVIDER=saml
METABASE_SSO_URL=${METABASE_SSO_URL}

# =============================================================================
# MONITORING & TELEMETRY (CRITICAL for production)
# =============================================================================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=30
PROMETHEUS_REMOTE_WRITE_ENABLED=true
PROMETHEUS_REMOTE_WRITE_URL=${PROMETHEUS_REMOTE_WRITE_URL}

# Grafana
GRAFANA_ENABLED=true
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}

# Distributed Tracing (RECOMMENDED for production)
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger.internal
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLING_RATE=0.1

# Metrics Collection
METRICS_INTERVAL=10000
HEALTH_CHECK_INTERVAL=15000

# Audit Logging (REQUIRED for production)
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_S3_BUCKET=${AUDIT_LOG_S3_BUCKET}

# =============================================================================
# EMAIL/SMTP (REQUIRED for production)
# =============================================================================
SMTP_ENABLED=true
SMTP_HOST=smtp.internal
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=noreply@configbuddy.com

# Alert Recipients (production oncall)
ALERT_EMAIL_RECIPIENTS=${ALERT_EMAIL_RECIPIENTS}
ALERT_SLACK_WEBHOOK=${SLACK_WEBHOOK_PRODUCTION}
ALERT_PAGERDUTY_KEY=${PAGERDUTY_KEY}

# =============================================================================
# WEB UI
# =============================================================================
WEB_UI_PORT=3001
WEB_UI_API_URL=https://api.configbuddy.com

# =============================================================================
# FEATURE FLAGS (All enabled for production)
# =============================================================================
FEATURE_AI_DISCOVERY=true
FEATURE_PATTERN_LEARNING=true
FEATURE_AGENTIC_AI=true
FEATURE_EVENT_STREAMING=true
FEATURE_ADVANCED_ANALYTICS=true

# =============================================================================
# SECURITY SETTINGS (CRITICAL - DO NOT DISABLE)
# =============================================================================
# TLS/SSL (REQUIRED)
TLS_ENABLED=true
TLS_CERT_PATH=/certs/tls.crt
TLS_KEY_PATH=/certs/tls.key
TLS_CA_PATH=/certs/ca.crt
TLS_MIN_VERSION=1.2

# CORS (Restrictive for production)
CORS_ENABLED=true
CORS_ORIGINS=https://configbuddy.com,https://api.configbuddy.com,https://bi.configbuddy.com
CORS_CREDENTIALS=true

# CSP (Content Security Policy) - Strict
CSP_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.configbuddy.com

# HSTS (HTTP Strict Transport Security)
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# X-Frame-Options
X_FRAME_OPTIONS=DENY

# Security Headers
SECURITY_HEADERS_ENABLED=true

# =============================================================================
# KUBERNETES DEPLOYMENT SETTINGS
# =============================================================================
# High Availability Replicas
API_SERVER_REPLICAS=3
DISCOVERY_ENGINE_REPLICAS=3
WEB_UI_REPLICAS=2

# Resource Limits (Production-grade)
API_SERVER_CPU_REQUEST=1000m
API_SERVER_CPU_LIMIT=4000m
API_SERVER_MEMORY_REQUEST=2Gi
API_SERVER_MEMORY_LIMIT=8Gi

DISCOVERY_ENGINE_CPU_REQUEST=1000m
DISCOVERY_ENGINE_CPU_LIMIT=4000m
DISCOVERY_ENGINE_MEMORY_REQUEST=2Gi
DISCOVERY_ENGINE_MEMORY_LIMIT=8Gi

# Pod Disruption Budgets
API_SERVER_MIN_AVAILABLE=2
DISCOVERY_ENGINE_MIN_AVAILABLE=2

# Horizontal Pod Autoscaling
HPA_ENABLED=true
HPA_MIN_REPLICAS=3
HPA_MAX_REPLICAS=10
HPA_CPU_TARGET=70
HPA_MEMORY_TARGET=80

# =============================================================================
# BACKUP CONFIGURATION (CRITICAL)
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 1 * * *
BACKUP_RETENTION_DAYS=90
BACKUP_S3_BUCKET=${BACKUP_S3_BUCKET}
BACKUP_S3_REGION=us-east-1
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_KEY=${BACKUP_ENCRYPTION_KEY}

# Point-in-Time Recovery
POSTGRES_WAL_ARCHIVING_ENABLED=true
POSTGRES_WAL_S3_BUCKET=${POSTGRES_WAL_S3_BUCKET}

# Backup Verification
BACKUP_VERIFICATION_ENABLED=true
BACKUP_VERIFICATION_SCHEDULE=0 6 * * 0

# =============================================================================
# DISASTER RECOVERY
# =============================================================================
DR_ENABLED=true
DR_REGION=us-west-2
DR_REPLICATION_ENABLED=true
DR_RTO_HOURS=4
DR_RPO_HOURS=1

# =============================================================================
# CLOUD PROVIDER CREDENTIALS
# =============================================================================
# IMPORTANT: DO NOT SET CLOUD CREDENTIALS HERE
# Configure all connector credentials via the Web UI or API using the unified credential system
# This ensures proper encryption, auditing, and access control

# AWS - DO NOT USE (configure via unified credentials)
# AWS_ACCESS_KEY_ID - NOT USED
# AWS_SECRET_ACCESS_KEY - NOT USED

# Azure - DO NOT USE (configure via unified credentials)
# AZURE_CLIENT_ID - NOT USED
# AZURE_CLIENT_SECRET - NOT USED
# AZURE_TENANT_ID - NOT USED

# GCP - DO NOT USE (configure via unified credentials)
# GCP_PROJECT_ID - NOT USED
# GCP_SERVICE_ACCOUNT_KEY_PATH - NOT USED

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
# ServiceNow (credentials via unified system)
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_CMDB_SYNC_ENABLED=true
SERVICENOW_INCIDENT_INTEGRATION_ENABLED=true

# PagerDuty (production oncall)
PAGERDUTY_API_KEY=${PAGERDUTY_API_KEY}
PAGERDUTY_SERVICE_KEY=${PAGERDUTY_SERVICE_KEY}
PAGERDUTY_ESCALATION_POLICY=${PAGERDUTY_ESCALATION_POLICY}

# Slack (production alerts)
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_PRODUCTION}
SLACK_CHANNEL=#configbuddy-production-alerts

# Jira (change management)
JIRA_URL=https://your-instance.atlassian.net
JIRA_PROJECT_KEY=CMDB
JIRA_CHANGE_ISSUE_TYPE=Change

# =============================================================================
# COMPLIANCE & GOVERNANCE
# =============================================================================
# SOC 2 / ISO 27001
COMPLIANCE_AUDIT_ENABLED=true
COMPLIANCE_LOG_RETENTION_YEARS=7

# GDPR
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=2555
GDPR_RIGHT_TO_DELETION_ENABLED=true

# HIPAA (if applicable)
HIPAA_ENABLED=false
HIPAA_ENCRYPTION_AT_REST=true
HIPAA_ENCRYPTION_IN_TRANSIT=true

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Database Query Caching
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL=300
QUERY_CACHE_MAX_SIZE=1000

# API Response Caching
API_CACHE_ENABLED=true
API_CACHE_TTL=60
API_CACHE_MAX_SIZE=10000

# CDN (for static assets)
CDN_ENABLED=true
CDN_URL=${CDN_URL}

# =============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# =============================================================================
# CRITICAL CHECKLIST:
# ✓ All secrets stored in Kubernetes secrets or vault
# ✓ TLS/SSL enabled with valid certificates
# ✓ SASL authentication enabled for Kafka
# ✓ Database passwords rotated regularly
# ✓ Backup procedures tested
# ✓ Disaster recovery plan documented and tested
# ✓ Monitoring and alerting configured
# ✓ Security audit completed
# ✓ Penetration testing completed
# ✓ Load testing completed
# ✓ Runbooks created for common operations
# ✓ On-call rotation established
# ✓ Change management process in place
# ✓ Incident response plan documented
#
# NEVER in production:
# ✗ Hardcoded secrets
# ✗ Debug mode enabled
# ✗ Disabled rate limiting
# ✗ Disabled TLS/SSL
# ✗ Overly permissive CORS
# ✗ Disabled audit logging
# ✗ No backups
# ✗ No monitoring
#
# Secrets Management:
# - Store ALL secrets in Kubernetes secrets or vault
# - Use ${VAR_NAME} syntax to reference secrets from secrets manager
# - Rotate secrets regularly (every 90 days minimum)
# - Never commit secrets to version control
# - Audit secret access regularly
#
# High Availability Requirements:
# - Minimum 3 replicas for critical services
# - Multi-AZ deployment
# - Database read replicas
# - Redis Sentinel
# - Kafka cluster with replication factor 3
#
# Monitoring Requirements:
# - Prometheus scraping all services
# - Grafana dashboards for all components
# - 31 alert rules configured
# - PagerDuty integration for critical alerts
# - Log aggregation (ELK/Loki)
# - Distributed tracing (Jaeger)
#
# For detailed deployment instructions, see:
# - /docs/PRE_DEPLOYMENT_CHECKLIST.md
# - /doc-site/docs/deployment/
# - /doc-site/docs/operations/
