# ConfigBuddy v3.0 Staging Environment Configuration
# This configuration mirrors production but with lower resource limits
# Use for final pre-production testing and validation

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=staging
LOG_LEVEL=info
API_PORT=3000
API_HOST=0.0.0.0

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# IMPORTANT: Generate unique secrets for staging
# openssl rand -base64 32
JWT_SECRET=REPLACE-WITH-STAGING-JWT-SECRET-MINIMUM-32-CHARACTERS
JWT_EXPIRATION=8h
ENCRYPTION_KEY=REPLACE-WITH-STAGING-ENCRYPTION-KEY-MINIMUM-32-CHARS

# API Security
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500
BCRYPT_ROUNDS=12

# =============================================================================
# NEO4J GRAPH DATABASE
# =============================================================================
NEO4J_URI=bolt://neo4j-staging.internal:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=${NEO4J_PASSWORD}
NEO4J_DATABASE=cmdb
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60000

# =============================================================================
# POSTGRESQL (Connector Registry, Credentials, Metadata)
# =============================================================================
POSTGRES_HOST=postgres-staging.internal
POSTGRES_PORT=5432
POSTGRES_DATABASE=cmdb_datamart
POSTGRES_USER=cmdb_user
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_IDLE_TIMEOUT_MS=10000
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# =============================================================================
# REDIS (Cache & Job Queue)
# =============================================================================
REDIS_HOST=redis-staging.internal
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000

# =============================================================================
# DISCOVERY CONFIGURATION
# =============================================================================
DISCOVERY_ENABLED=true
DISCOVERY_DEFAULT_INTERVAL=3600000
DISCOVERY_BATCH_SIZE=100
DISCOVERY_CONCURRENCY=5
DISCOVERY_TIMEOUT=600000

# =============================================================================
# v3.0 UNIFIED FRAMEWORK
# =============================================================================
V3_UNIFIED_FRAMEWORK_ENABLED=true
ITIL_ENABLED=true
TBM_ENABLED=true
BSM_ENABLED=true
UNIFIED_VIEW_CACHE_TTL=300

# =============================================================================
# ITIL SERVICE MANAGER
# =============================================================================
ITIL_PRIORITY_CALCULATION_ENABLED=true
ITIL_CHANGE_RISK_ENABLED=true
ITIL_BASELINE_MANAGEMENT_ENABLED=true
ITIL_CAB_APPROVAL_THRESHOLD=50
ITIL_EXECUTIVE_APPROVAL_THRESHOLD=75
ITIL_P1_RESPONSE_MINUTES=15
ITIL_P1_RESOLUTION_MINUTES=240
ITIL_DRIFT_CHECK_ENABLED=true
ITIL_DRIFT_SEVERITY_THRESHOLD=30

# =============================================================================
# TBM COST ENGINE
# =============================================================================
TBM_COST_ALLOCATION_ENABLED=true
TBM_DEPRECIATION_METHOD=straight_line
TBM_DEFAULT_DEPRECIATION_YEARS=3
TBM_CLOUD_SYNC_ENABLED=true
TBM_CLOUD_SYNC_INTERVAL=86400000
TBM_AWS_COST_EXPLORER_ENABLED=true
TBM_AZURE_COST_MGMT_ENABLED=true
TBM_GCP_BILLING_ENABLED=true
TBM_LICENSE_TRACKING_ENABLED=true
TBM_LICENSE_RENEWAL_ALERT_DAYS=30
TBM_BUDGET_VARIANCE_THRESHOLD=10
TBM_COST_ANOMALY_ENABLED=true

# =============================================================================
# BSM IMPACT ENGINE
# =============================================================================
BSM_ENABLED=true
BSM_BATCH_SIZE=100
BSM_MAX_BLAST_RADIUS_HOPS=8
BSM_TIER_0_THRESHOLD=1000000
BSM_TIER_1_THRESHOLD=500000
BSM_TIER_2_THRESHOLD=100000
BSM_TIER_3_THRESHOLD=10000
BSM_WEIGHT_REVENUE=0.40
BSM_WEIGHT_CUSTOMERS=0.25
BSM_WEIGHT_TRANSACTIONS=0.15
BSM_WEIGHT_COMPLIANCE=0.10
BSM_WEIGHT_USERS=0.10
BSM_RISK_INCIDENT_WEIGHT=0.30
BSM_RISK_CHANGE_WEIGHT=0.25
BSM_RISK_AVAILABILITY_WEIGHT=0.25
BSM_RISK_COMPLIANCE_WEIGHT=0.10
BSM_RISK_AUDIT_WEIGHT=0.10
BSM_BLAST_RADIUS_TIMEOUT=300000
BSM_GRAPH_TRAVERSAL_CACHE_TTL=300

# =============================================================================
# AI/ML ENGINE
# =============================================================================
# Anomaly Detection
AI_ANOMALY_DETECTION_ENABLED=true
AI_ANOMALY_SENSITIVITY=medium
AI_ANOMALY_MIN_CONFIDENCE=70
AI_ANOMALY_CHECK_INTERVAL=60
AI_ANOMALY_LOOKBACK_DAYS=30

# Configuration Drift Detection
AI_DRIFT_DETECTION_ENABLED=true
AI_DRIFT_SEVERITY_THRESHOLD=30
AI_DRIFT_AUTO_BASELINE_ENABLED=true

# Impact Prediction
AI_IMPACT_PREDICTION_ENABLED=true
AI_IMPACT_MAX_BLAST_RADIUS=200
AI_IMPACT_CRITICALITY_CACHE_TTL=604800

# =============================================================================
# AI DISCOVERY (Agentic AI) - LIMITED BUDGET FOR STAGING
# =============================================================================
AI_DISCOVERY_ENABLED=true
AI_DISCOVERY_LLM_PROVIDER=anthropic
AI_DISCOVERY_MODEL=claude-3-5-sonnet-20241022

# LLM API Keys (use dedicated staging keys)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY_STAGING}
OPENAI_API_KEY=${OPENAI_API_KEY_STAGING}

# AI Discovery Budgets (staging - limited budget)
AI_DISCOVERY_MAX_COST_PER_SESSION=2.00
AI_DISCOVERY_MONTHLY_BUDGET=50.00
AI_DISCOVERY_COST_WARNING_THRESHOLD=0.80
AI_DISCOVERY_COST_ALERT_THRESHOLD=0.95

# AI Discovery Performance
AI_DISCOVERY_MAX_ITERATIONS=10
AI_DISCOVERY_TIMEOUT=300000
AI_DISCOVERY_CONCURRENCY=2

# =============================================================================
# EVENT STREAMING (KAFKA)
# =============================================================================
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka-1-staging.internal:9092,kafka-2-staging.internal:9092
KAFKA_CLIENT_ID=cmdb-staging
KAFKA_GROUP_ID=cmdb-consumers-staging
KAFKA_CONNECTION_TIMEOUT=30000
KAFKA_REQUEST_TIMEOUT=30000

# Kafka Security (TLS enabled, SASL optional)
KAFKA_SSL_ENABLED=true
KAFKA_SSL_CA_PATH=/certs/kafka-ca.crt
KAFKA_SSL_CERT_PATH=/certs/kafka-client.crt
KAFKA_SSL_KEY_PATH=/certs/kafka-client.key
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Kafka Topic Configuration
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_REPLICATION_FACTOR=2
KAFKA_PARTITIONS_DEFAULT=6
KAFKA_RETENTION_HOURS=168
KAFKA_COMPRESSION_TYPE=snappy

# =============================================================================
# METABASE BUSINESS INTELLIGENCE
# =============================================================================
METABASE_ENABLED=true
METABASE_PORT=3002
METABASE_DATABASE=metabase
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=${METABASE_DB_PASSWORD}
METABASE_ENCRYPTION_KEY=${METABASE_ENCRYPTION_KEY}
METABASE_SITE_URL=https://bi-staging.configbuddy.internal
METABASE_READONLY_USER=metabase_readonly
METABASE_READONLY_PASSWORD=${METABASE_READONLY_PASSWORD}
METABASE_AUTO_SYNC_ENABLED=true
METABASE_AUTO_SYNC_SCHEDULE=0 3 * * *

# =============================================================================
# MONITORING & TELEMETRY
# =============================================================================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true

# Distributed Tracing (optional for staging)
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger-staging.internal
JAEGER_AGENT_PORT=6831

# Metrics Collection
METRICS_INTERVAL=15000
HEALTH_CHECK_INTERVAL=30000

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=30

# =============================================================================
# EMAIL/SMTP
# =============================================================================
SMTP_ENABLED=true
SMTP_HOST=smtp-staging.internal
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=noreply@configbuddy-staging.internal

# Alert Recipients (staging team)
ALERT_EMAIL_RECIPIENTS=staging-team@example.com
ALERT_SLACK_WEBHOOK=${SLACK_WEBHOOK_STAGING}

# =============================================================================
# WEB UI
# =============================================================================
WEB_UI_PORT=3001
WEB_UI_API_URL=https://api-staging.configbuddy.internal

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_DISCOVERY=true
FEATURE_PATTERN_LEARNING=true
FEATURE_AGENTIC_AI=true
FEATURE_EVENT_STREAMING=true
FEATURE_ADVANCED_ANALYTICS=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# TLS/SSL
TLS_ENABLED=true
TLS_CERT_PATH=/certs/tls.crt
TLS_KEY_PATH=/certs/tls.key
TLS_CA_PATH=/certs/ca.crt

# CORS
CORS_ENABLED=true
CORS_ORIGINS=https://staging.configbuddy.internal,https://bi-staging.configbuddy.internal

# CSP (Content Security Policy)
CSP_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline'

# =============================================================================
# KUBERNETES DEPLOYMENT SETTINGS
# =============================================================================
# Replicas (moderate for staging)
API_SERVER_REPLICAS=2
DISCOVERY_ENGINE_REPLICAS=2
WEB_UI_REPLICAS=1

# Resource Limits (moderate)
API_SERVER_CPU_REQUEST=500m
API_SERVER_CPU_LIMIT=2000m
API_SERVER_MEMORY_REQUEST=1Gi
API_SERVER_MEMORY_LIMIT=4Gi

DISCOVERY_ENGINE_CPU_REQUEST=500m
DISCOVERY_ENGINE_CPU_LIMIT=2000m
DISCOVERY_ENGINE_MEMORY_REQUEST=1Gi
DISCOVERY_ENGINE_MEMORY_LIMIT=4Gi

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_S3_BUCKET=configbuddy-staging-backups
BACKUP_S3_REGION=us-east-1

# =============================================================================
# CLOUD PROVIDER CREDENTIALS
# =============================================================================
# IMPORTANT: Configure these via the Web UI or API using the unified credential system
# DO NOT set cloud credentials here as environment variables

# AWS (configure via UI)
# AWS_ACCESS_KEY_ID - NOT USED (use unified credentials)
# AWS_SECRET_ACCESS_KEY - NOT USED (use unified credentials)

# Azure (configure via UI)
# AZURE_CLIENT_ID - NOT USED (use unified credentials)
# AZURE_CLIENT_SECRET - NOT USED (use unified credentials)
# AZURE_TENANT_ID - NOT USED (use unified credentials)

# GCP (configure via UI)
# GCP_PROJECT_ID - NOT USED (use unified credentials)
# GCP_SERVICE_ACCOUNT_KEY_PATH - NOT USED (use unified credentials)

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
# ServiceNow (configure credentials via UI)
SERVICENOW_INSTANCE_URL=https://your-instance-staging.service-now.com

# PagerDuty
PAGERDUTY_API_KEY=${PAGERDUTY_API_KEY_STAGING}
PAGERDUTY_SERVICE_KEY=${PAGERDUTY_SERVICE_KEY_STAGING}

# Slack
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_STAGING}
SLACK_CHANNEL=#configbuddy-staging-alerts

# =============================================================================
# NOTES
# =============================================================================
# This staging configuration should mirror production as closely as possible:
# - All v3.0 features enabled
# - Kafka event streaming enabled
# - AI Discovery enabled with budget limits
# - Metabase BI enabled
# - Full monitoring and alerting
# - TLS/SSL enabled
# - Lower resource limits than production
# - Shorter retention periods
#
# Use staging to:
# - Final integration testing
# - Load testing
# - Security testing
# - Disaster recovery testing
# - User acceptance testing
#
# Secrets Management:
# - Store secrets in Kubernetes secrets or vault
# - Use ${VAR_NAME} syntax to reference secrets
# - Never commit actual secrets to version control
#
# For production configuration, see production.env.example
