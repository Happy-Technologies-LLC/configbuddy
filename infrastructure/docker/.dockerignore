docs/
reviews/

# CI/CD
.gitlab-ci.yml
.travis.yml
.circleci/

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
logs/
*.log

# Temp files
tmp/
temp/
*.tmp

