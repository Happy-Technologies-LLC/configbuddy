.env
.env.*
!.env.example
*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.claude/

# Git
.git/
.gitignore
.gitattributes
.github/
.husky/

# Documentation (except key README files)
