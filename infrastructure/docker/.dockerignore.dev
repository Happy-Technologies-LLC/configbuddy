# Dependencies - exclude to reduce size
**/node_modules/
npm-debug.log*
package-lock.json

# Source files - we only need dist
packages/**/src/
web-ui/src/
packages/**/*.ts
packages/**/*.tsx
!packages/**/*.d.ts

# Testing
coverage/
**/*.test.ts
**/*.spec.ts
**/__tests__/
**/__mocks__/
tests/

# Environment files
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
.DS_Store
.claude/

# Git
.git/
.gitignore
.github/
.husky/

# Documentation
*.md
!README.md
docs/
reviews/

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore*

# Logs
logs/
*.log

# Temp files
tmp/
temp/

# Scripts not needed
scripts/

# Config files not needed at runtime
.prettierrc*
.eslintrc*
.editorconfig
jest.config*.js

# Examples
examples/
demo/
samples/

# Kubernetes and terraform
kubernetes/
terraform/

# Phase docs
PHASE*.md
TEST_*.md
