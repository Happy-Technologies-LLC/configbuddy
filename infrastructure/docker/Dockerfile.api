# Production Dockerfile for API Server
FROM node:20-alpine AS builder

# Install build dependencies
RUN apk add --no-cache python3 make g++ git

WORKDIR /app

# Copy ALL package files (root + workspaces)
COPY package*.json ./
COPY packages/common/package.json ./packages/common/
COPY packages/database/package.json ./packages/database/
COPY packages/discovery-engine/package.json ./packages/discovery-engine/
COPY packages/etl-processor/package.json ./packages/etl-processor/
COPY packages/event-processor/package.json ./packages/event-processor/
COPY packages/ai-ml-engine/package.json ./packages/ai-ml-engine/
COPY packages/data-mapper/package.json ./packages/data-mapper/
COPY packages/integration-framework/package.json ./packages/integration-framework/
COPY packages/integration-hub/package.json ./packages/integration-hub/
COPY packages/api-server/package.json ./packages/api-server/

# Install ALL dependencies including devDependencies (needed for TypeScript, prom-client, etc.)
RUN npm install

# Copy tsconfig files
COPY tsconfig.base.json ./
COPY tsconfig.json ./

# Copy source files
COPY packages/common ./packages/common
COPY packages/database ./packages/database
COPY packages/discovery-engine ./packages/discovery-engine
COPY packages/etl-processor ./packages/etl-processor
COPY packages/event-processor ./packages/event-processor
COPY packages/ai-ml-engine ./packages/ai-ml-engine
COPY packages/data-mapper ./packages/data-mapper
COPY packages/integration-framework ./packages/integration-framework
COPY packages/integration-hub ./packages/integration-hub
COPY packages/api-server ./packages/api-server
COPY packages/connectors ./packages/connectors

# Build TypeScript packages in dependency order
WORKDIR /app/packages/common
RUN npm run build

WORKDIR /app/packages/database
RUN npm run build

WORKDIR /app/packages/discovery-engine
RUN npm run build

WORKDIR /app/packages/etl-processor
RUN npm run build

WORKDIR /app/packages/event-processor
RUN npm run build

WORKDIR /app/packages/ai-ml-engine
RUN npm run build

WORKDIR /app/packages/data-mapper
RUN npm run build

WORKDIR /app/packages/integration-framework
RUN npm run build

WORKDIR /app/packages/integration-hub
RUN npm run build

WORKDIR /app/packages/api-server
RUN npm run build

# Production stage
FROM node:20-alpine

# Install runtime dependencies (including nmap for network discovery)
RUN apk add --no-cache dumb-init curl nmap nmap-scripts libcap

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

WORKDIR /app

# Copy package files
COPY package*.json ./

# Copy ALL built packages and node_modules from builder
# This avoids workspace resolution issues in production
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages

# Change ownership
RUN chown -R nodejs:nodejs /app

# Give nmap capabilities for network scanning without full root
# Note: OS detection (-O) still requires root, but basic scans will work
RUN setcap cap_net_raw,cap_net_admin,cap_net_bind_service+eip /usr/bin/nmap || true

# Switch to non-root user
USER nodejs

# Expose API port
EXPOSE 3000

# Set environment variables
ENV NODE_ENV=production \
    PORT=3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:3000/health || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

# Start the API server
CMD ["node", "packages/api-server/dist/index.js"]
