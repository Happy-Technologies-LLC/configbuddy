# Production Dockerfile for Web UI
FROM node:20-alpine AS builder

WORKDIR /app

# Copy ALL package files
COPY package*.json ./
COPY web-ui/package.json ./web-ui/

# Install ALL dependencies (including devDependencies)
RUN npm install

# Copy tsconfig files
COPY tsconfig.base.json ./

# Copy web-ui source
COPY web-ui ./web-ui

# Build production bundle
RUN npm run build --workspace=web-ui

# Production stage with nginx
FROM nginx:1.25-alpine

# Install dumb-init for proper signal handling
RUN apk add --no-cache dumb-init

# Create non-root nginx user (nginx user already exists in nginx:alpine)
# Change ownership of nginx directories to nginx user
RUN chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    chown -R nginx:nginx /etc/nginx/conf.d && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid

# Create directory for static files with proper permissions
RUN mkdir -p /usr/share/nginx/html && \
    chown -R nginx:nginx /usr/share/nginx/html

# Copy built files from builder
COPY --from=builder --chown=nginx:nginx /app/web-ui/dist /usr/share/nginx/html

# Copy nginx configuration
COPY --chown=nginx:nginx web-ui/nginx.conf /etc/nginx/conf.d/default.conf

# Switch to non-root user
USER nginx

# Expose port 80
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost/ || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
