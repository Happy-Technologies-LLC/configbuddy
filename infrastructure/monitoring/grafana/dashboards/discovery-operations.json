{
  "dashboard": {
    "title": "CMDB Discovery Operations",
    "tags": ["cmdb", "discovery", "operations"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Discovery Jobs Completed vs Failed",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (provider) (rate(cmdb_discovery_jobs_total{status=\"success\"}[5m]))",
            "legendFormat": "{{provider}} - Success",
            "refId": "A"
          },
          {
            "expr": "sum by (provider) (rate(cmdb_discovery_jobs_total{status=\"failure\"}[5m]))",
            "legendFormat": "{{provider}} - Failed",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "jobs/sec",
            "format": "short"
          }
        ]
      },
      {
        "id": 2,
        "title": "CIs Discovered per Provider",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (provider) (rate(cmdb_cis_discovered_total[5m]))",
            "legendFormat": "{{provider}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "CIs/sec",
            "format": "short"
          }
        ]
      },
      {
        "id": 3,
        "title": "Discovery Job Duration (p95)",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(cmdb_discovery_job_duration_seconds_bucket[5m])))",
            "legendFormat": "{{provider}} p95",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "duration",
            "format": "s"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active Discovery Jobs",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "cmdb_discovery_jobs_active",
            "legendFormat": "{{provider}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "active jobs",
            "format": "short"
          }
        ]
      },
      {
        "id": 5,
        "title": "Confidence Score Distribution",
        "type": "heatmap",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (le) (rate(cmdb_discovery_confidence_score_bucket[5m]))",
            "legendFormat": "{{le}}",
            "format": "heatmap",
            "refId": "A"
          }
        ],
        "dataFormat": "tsbuckets"
      },
      {
        "id": 6,
        "title": "CIs by Type",
        "type": "piechart",
        "gridPos": {
          "x": 12,
          "y": 16,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (ci_type) (rate(cmdb_cis_discovered_total[1h]))",
            "legendFormat": "{{ci_type}}",
            "refId": "A"
          }
        ],
        "pieType": "pie"
      },
      {
        "id": 7,
        "title": "Discovery API Calls",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 24,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (provider, service) (rate(cmdb_discovery_api_calls_total[5m]))",
            "legendFormat": "{{provider}} - {{service}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "API calls/sec",
            "format": "short"
          }
        ]
      },
      {
        "id": 8,
        "title": "Rate Limit Hits",
        "type": "graph",
        "gridPos": {
          "x": 12,
          "y": 24,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (provider) (rate(cmdb_discovery_rate_limit_hits_total[5m]))",
            "legendFormat": "{{provider}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "rate limit hits/sec",
            "format": "short"
          }
        ]
      },
      {
        "id": 9,
        "title": "Discovery Errors by Provider",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 32,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "sum by (provider, error_type) (rate(cmdb_discovery_errors_total[5m]))",
            "legendFormat": "{{provider}} - {{error_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "errors/sec",
            "format": "short"
          }
        ]
      }
    ]
  }
}
