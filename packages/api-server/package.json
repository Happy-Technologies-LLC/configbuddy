{
  "name": "@cmdb/api-server",
  "version": "1.0.0",
  "description": "REST and GraphQL API server for CMDB platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "docs:validate": "npx @redocly/cli lint src/openapi/openapi.yaml",
    "docs:bundle": "npx @redocly/cli bundle src/openapi/openapi.yaml -o dist/openapi.json",
    "docs:serve": "npx @redocly/cli preview-docs src/openapi/openapi.yaml"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@cmdb/common": "*",
    "@cmdb/database": "*",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "express": "^4.0.0",
    "graphql": "^16.8.1",
    "helmet": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "neo4j-driver": "^5.15.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.0",
    "@types/yamljs": "^0.2.34",
    "supertest": "^6.3.3",
    "typescript": "^5.0.0"
  }
}
