{
  "id": "aws",
  "category": "connector",
  "connector_category": "cloud",
  "data_types": ["infrastructure", "financial"],
  "name": "AWS",
  "version": "2.0.0",
  "type": "aws",
  "description": "Cloud infrastructure and financial integration for AWS - discovers EC2 instances, RDS databases, S3 buckets, ECS containers, Lambda functions, and syncs cost & usage data via AWS APIs",
  "provider": "aws",
  "protocol": "aws_iam",
  "logo_url": "https://upload.wikimedia.org/wikipedia/commons/9/93/Amazon_Web_Services_Logo.svg",
  "documentation_url": "https://docs.aws.amazon.com/",
  "resources": [
    {
      "id": "ec2-instance",
      "name": "EC2 Instance",
      "type": "virtual-machine",
      "description": "AWS EC2 virtual machine instances",
      "field_mappings": {
        "name": "Tags.Name",
        "external_id": "InstanceId",
        "status": "State.Name",
        "ip_address": "PrivateIpAddress",
        "hostname": "PrivateDnsName",
        "instance_type": "InstanceType",
        "availability_zone": "Placement.AvailabilityZone",
        "vpc_id": "VpcId",
        "subnet_id": "SubnetId",
        "public_ip": "PublicIpAddress",
        "launch_time": "LaunchTime",
        "platform": "Platform",
        "architecture": "Architecture",
        "image_id": "ImageId",
        "key_name": "KeyName",
        "monitoring_state": "Monitoring.State",
        "iam_instance_profile": "IamInstanceProfile.Arn",
        "aws_region": "_aws_region"
      }
    },
    {
      "id": "rds-instance",
      "name": "RDS Database Instance",
      "type": "database",
      "description": "AWS RDS managed database instances",
      "field_mappings": {
        "name": "DBInstanceIdentifier",
        "external_id": "DbiResourceId",
        "status": "DBInstanceStatus",
        "hostname": "Endpoint.Address",
        "engine": "Engine",
        "engine_version": "EngineVersion",
        "instance_class": "DBInstanceClass",
        "allocated_storage": "AllocatedStorage",
        "storage_type": "StorageType",
        "port": "Endpoint.Port",
        "availability_zone": "AvailabilityZone",
        "multi_az": "MultiAZ",
        "publicly_accessible": "PubliclyAccessible",
        "storage_encrypted": "StorageEncrypted",
        "backup_retention_period": "BackupRetentionPeriod",
        "auto_minor_version_upgrade": "AutoMinorVersionUpgrade",
        "created_at": "InstanceCreateTime",
        "aws_region": "_aws_region"
      }
    },
    {
      "id": "s3-bucket",
      "name": "S3 Bucket",
      "type": "storage",
      "description": "AWS S3 object storage buckets",
      "field_mappings": {
        "name": "Name",
        "external_id": "Name",
        "created_at": "CreationDate",
        "versioning_status": "_versioning_status",
        "aws_region": "_aws_region"
      }
    },
    {
      "id": "lambda-function",
      "name": "Lambda Function",
      "type": "application",
      "description": "AWS Lambda serverless functions",
      "field_mappings": {
        "name": "FunctionName",
        "external_id": "FunctionArn",
        "description": "Description",
        "runtime": "Runtime",
        "handler": "Handler",
        "code_size": "CodeSize",
        "timeout": "Timeout",
        "memory_size": "MemorySize",
        "last_modified": "LastModified",
        "role": "Role",
        "state": "State",
        "aws_region": "_aws_region"
      }
    },
    {
      "id": "ecs-cluster",
      "name": "ECS Cluster",
      "type": "cloud-resource",
      "description": "AWS ECS container orchestration clusters",
      "field_mappings": {
        "name": "clusterName",
        "external_id": "clusterArn",
        "status": "status",
        "resource_type": "_resource_type",
        "running_tasks_count": "runningTasksCount",
        "pending_tasks_count": "pendingTasksCount",
        "active_services_count": "activeServicesCount",
        "aws_region": "_aws_region"
      }
    },
    {
      "id": "cost-usage",
      "name": "Cost & Usage",
      "type": "cost-record",
      "data_type": "financial",
      "description": "Daily cost and usage data from AWS Cost Explorer API",
      "target_storage": "postgresql:tbm_cost_pools",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "granularity": {
            "type": "string",
            "enum": ["DAILY", "HOURLY", "MONTHLY"],
            "default": "DAILY",
            "description": "Cost data granularity"
          },
          "metrics": {
            "type": "array",
            "items": {
              "enum": ["UnblendedCost", "BlendedCost", "AmortizedCost", "UsageQuantity"]
            },
            "default": ["UnblendedCost", "UsageQuantity"],
            "description": "Cost metrics to retrieve"
          },
          "group_by": {
            "type": "array",
            "items": {
              "enum": ["SERVICE", "LINKED_ACCOUNT", "REGION", "USAGE_TYPE", "TAG", "INSTANCE_TYPE"]
            },
            "default": ["SERVICE"],
            "description": "Dimensions to group costs by"
          },
          "lookback_days": {
            "type": "integer",
            "minimum": 1,
            "maximum": 90,
            "default": 30,
            "description": "Number of days to retrieve historical cost data"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 1000,
        "rate_limit": 5
      },
      "field_mappings": {
        "time_period_start": "TimePeriod.Start",
        "time_period_end": "TimePeriod.End",
        "service": "Keys.0",
        "unblended_cost": "Metrics.UnblendedCost.Amount",
        "usage_quantity": "Metrics.UsageQuantity.Amount",
        "currency": "Metrics.UnblendedCost.Unit",
        "account_id": "_account_id",
        "region": "_region"
      },
      "transformation": {
        "tbm_tower_mapping": {
          "AmazonEC2": "compute",
          "AmazonRDS": "data",
          "AmazonS3": "storage",
          "AmazonCloudFront": "network",
          "AmazonLambda": "compute",
          "AmazonDynamoDB": "data",
          "AmazonECS": "compute",
          "AmazonEKS": "compute",
          "AmazonElastiCache": "data",
          "AmazonRedshift": "data",
          "AmazonVPC": "network",
          "ElasticLoadBalancing": "network",
          "AmazonRoute53": "network",
          "AWSDirectConnect": "network",
          "AmazonGuardDuty": "security",
          "AWSSecurityHub": "security",
          "AWSWAF": "security",
          "AmazonWorkSpaces": "end_user",
          "AmazonChime": "end_user",
          "AWSIoTCore": "iot",
          "AmazonQLDB": "blockchain",
          "AmazonBraket": "quantum"
        }
      }
    }
  ],
  "authentication": {
    "required": true,
    "methods": [
      "aws_iam"
    ],
    "fields": [
      {
        "name": "access_key_id",
        "label": "AWS Access Key ID",
        "type": "string",
        "required": true,
        "sensitive": false,
        "description": "AWS IAM access key ID"
      },
      {
        "name": "secret_access_key",
        "label": "AWS Secret Access Key",
        "type": "string",
        "required": true,
        "sensitive": true,
        "description": "AWS IAM secret access key"
      },
      {
        "name": "region",
        "label": "AWS Region",
        "type": "string",
        "required": false,
        "default": "us-east-1",
        "description": "AWS region to discover resources in"
      }
    ]
  },
  "capabilities": {
    "discovery": true,
    "sync": false,
    "real_time": false,
    "incremental": false
  },
  "rate_limits": {
    "requests_per_second": 10,
    "requests_per_minute": 500,
    "requests_per_hour": 10000
  },
  "supported_operations": [
    "discover_ec2",
    "discover_rds",
    "discover_s3",
    "discover_lambda",
    "discover_ecs",
    "sync_costs"
  ],
  "default_schedule": "0 */6 * * *",
  "tags": [
    "cloud",
    "aws",
    "infrastructure",
    "compute",
    "storage",
    "database",
    "serverless",
    "financial",
    "cost-management",
    "finops"
  ]
}
