{
  "id": "gcp",
  "category": "connector",
  "connector_category": "cloud",
  "data_types": ["infrastructure", "financial"],
  "name": "Google Cloud Platform",
  "version": "2.0.0",
  "type": "gcp",
  "description": "Cloud infrastructure and financial integration for Google Cloud Platform - discovers Compute Engine instances, Cloud SQL databases, Cloud Storage buckets, GKE clusters, Cloud Functions, and syncs cost data via GCP APIs and BigQuery Billing Export",
  "provider": "gcp",
  "protocol": "gcp_sa",
  "logo_url": "https://upload.wikimedia.org/wikipedia/commons/5/51/Google_Cloud_logo.svg",
  "documentation_url": "https://cloud.google.com/docs",
  "resources": [
    {
      "id": "compute-instance",
      "name": "Compute Engine Instance",
      "type": "virtual-machine",
      "description": "GCP Compute Engine virtual machine instances",
      "field_mappings": {
        "name": "name",
        "external_id": "selfLink",
        "status": "status",
        "instance_id": "id",
        "zone": "_zone",
        "machine_type": "_machine_type",
        "cpu_platform": "cpuPlatform",
        "creation_timestamp": "creationTimestamp",
        "description": "description",
        "can_ip_forward": "canIpForward",
        "network_interfaces": "_network_interfaces",
        "disks": "_disks",
        "service_accounts": "_service_accounts",
        "metadata_items": "_metadata_items",
        "tags": "_tags",
        "scheduling": "_scheduling",
        "deletion_protection": "deletionProtection",
        "labels": "labels",
        "gcp_project_id": "_gcp_project_id",
        "gcp_zone": "_gcp_zone"
      }
    },
    {
      "id": "cloud-sql-instance",
      "name": "Cloud SQL Database Instance",
      "type": "database",
      "description": "GCP Cloud SQL managed database instances",
      "field_mappings": {
        "name": "name",
        "external_id": "selfLink",
        "status": "state",
        "connection_name": "_connection_name",
        "database_version": "_database_version",
        "backend_type": "_backend_type",
        "region": "_region",
        "gce_zone": "_gce_zone",
        "current_disk_size": "_current_disk_size",
        "max_disk_size": "_max_disk_size",
        "ip_addresses": "_ip_addresses",
        "instance_type": "_instance_type",
        "project": "_project",
        "service_account_email": "_service_account_email_address",
        "tier": "_settings._tier",
        "pricing_plan": "_settings._pricing_plan",
        "storage_auto_resize": "_settings._storage_auto_resize",
        "availability_type": "_settings._availability_type",
        "data_disk_type": "_settings._data_disk_type",
        "data_disk_size_gb": "_settings._data_disk_size_gb",
        "backup_configuration": "_settings._backup_configuration",
        "maintenance_window": "_settings._maintenance_window",
        "database_flags": "_settings._database_flags",
        "ip_configuration": "_settings._ip_configuration",
        "replica_configuration": "_replica_configuration",
        "master_instance_name": "_master_instance_name",
        "replica_names": "_replica_names",
        "user_labels": "_user_labels",
        "gcp_project_id": "_gcp_project_id"
      }
    },
    {
      "id": "storage-bucket",
      "name": "Cloud Storage Bucket",
      "type": "storage",
      "description": "GCP Cloud Storage buckets",
      "field_mappings": {
        "name": "name",
        "external_id": "id",
        "location": "_location",
        "location_type": "_location_type",
        "storage_class": "_storage_class",
        "time_created": "_time_created",
        "updated": "_updated",
        "versioning": "_versioning",
        "logging": "_logging",
        "website": "_website",
        "lifecycle_rules": "_lifecycle_rules",
        "cors": "_cors",
        "encryption": "_encryption",
        "iam_configuration": "_iam_configuration",
        "default_event_based_hold": "_default_event_based_hold",
        "retention_policy": "_retention_policy",
        "requester_pays": "_requester_pays",
        "labels": "labels",
        "gcp_project_id": "_gcp_project_id",
        "self_link": "_self_link"
      }
    },
    {
      "id": "gke-cluster",
      "name": "GKE Cluster",
      "type": "cloud-resource",
      "description": "GCP Google Kubernetes Engine clusters",
      "field_mappings": {
        "name": "name",
        "external_id": "selfLink",
        "status": "status",
        "resource_type": "_resource_type",
        "cluster_id": "_cluster_id",
        "description": "_description",
        "location": "_location",
        "locations": "_locations",
        "current_master_version": "_current_master_version",
        "current_node_version": "_current_node_version",
        "initial_cluster_version": "_initial_cluster_version",
        "status_message": "_status_message",
        "node_ipv4_cidr_size": "_node_ipv4_cidr_size",
        "services_ipv4_cidr": "_services_ipv4_cidr",
        "cluster_ipv4_cidr": "_cluster_ipv4_cidr",
        "endpoint": "_endpoint",
        "initial_node_count": "_initial_node_count",
        "current_node_count": "_current_node_count",
        "node_pools": "_node_pools",
        "network_config": "_network_config",
        "addons_config": "_addons_config",
        "logging_service": "_logging_service",
        "monitoring_service": "_monitoring_service",
        "enable_kubernetes_alpha": "_enable_kubernetes_alpha",
        "enable_tpu": "_enable_tpu",
        "master_auth": "_master_auth",
        "maintenance_policy": "_maintenance_policy",
        "binary_authorization": "_binary_authorization",
        "autoscaling": "_autoscaling",
        "network_policy": "_network_policy",
        "resource_labels": "_resource_labels",
        "label_fingerprint": "_label_fingerprint",
        "create_time": "_create_time",
        "expire_time": "_expire_time",
        "gcp_project_id": "_gcp_project_id",
        "gcp_zone": "_gcp_zone"
      }
    },
    {
      "id": "cloud-function",
      "name": "Cloud Function",
      "type": "application",
      "description": "GCP Cloud Functions serverless functions",
      "field_mappings": {
        "name": "name",
        "external_id": "name",
        "full_name": "_full_name",
        "description": "_description",
        "status": "_status",
        "entry_point": "_entry_point",
        "runtime": "_runtime",
        "timeout": "_timeout",
        "available_memory_mb": "_available_memory_mb",
        "service_account_email": "_service_account_email",
        "update_time": "_update_time",
        "version_id": "_version_id",
        "source_archive_url": "_source_archive_url",
        "source_repository": "_source_repository",
        "source_upload_url": "_source_upload_url",
        "https_trigger": "_https_trigger",
        "event_trigger": "_event_trigger",
        "environment_variable_keys": "_environment_variable_keys",
        "build_environment_variable_keys": "_build_environment_variable_keys",
        "network": "_network",
        "vpc_connector": "_vpc_connector",
        "vpc_connector_egress_settings": "_vpc_connector_egress_settings",
        "ingress_settings": "_ingress_settings",
        "max_instances": "_max_instances",
        "build_id": "_build_id",
        "build_name": "_build_name",
        "labels": "labels",
        "gcp_project_id": "_gcp_project_id",
        "gcp_location": "_gcp_location"
      }
    },
    {
      "id": "cost-usage",
      "name": "Cost & Usage",
      "type": "cost-record",
      "data_type": "financial",
      "description": "Daily cost and usage data from GCP BigQuery Billing Export",
      "target_storage": "postgresql:tbm_cost_pools",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "billing_account_id": {
            "type": "string",
            "description": "GCP Billing Account ID"
          },
          "bigquery_dataset": {
            "type": "string",
            "description": "BigQuery dataset containing billing export (e.g., my_project.billing_export)"
          },
          "bigquery_table": {
            "type": "string",
            "description": "BigQuery table name pattern (e.g., gcp_billing_export_v1_*)"
          },
          "lookback_days": {
            "type": "integer",
            "minimum": 1,
            "maximum": 90,
            "default": 30,
            "description": "Number of days to retrieve historical cost data"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 1000,
        "rate_limit": 5
      },
      "field_mappings": {
        "usage_start_time": "usage_start_time",
        "usage_end_time": "usage_end_time",
        "service_description": "service.description",
        "sku_description": "sku.description",
        "project_id": "project.id",
        "project_name": "project.name",
        "location_region": "location.region",
        "location_zone": "location.zone",
        "cost": "cost",
        "usage_amount": "usage.amount",
        "usage_unit": "usage.unit",
        "currency": "currency",
        "labels": "labels"
      },
      "transformation": {
        "tbm_tower_mapping": {
          "Compute Engine": "compute",
          "Cloud SQL": "data",
          "Cloud Spanner": "data",
          "BigQuery": "data",
          "Cloud Storage": "storage",
          "Persistent Disk": "storage",
          "Cloud Filestore": "storage",
          "Virtual Private Cloud": "network",
          "Cloud Load Balancing": "network",
          "Cloud CDN": "network",
          "Cloud Armor": "security",
          "Security Command Center": "security",
          "Cloud Identity": "end_user",
          "Google Kubernetes Engine": "compute",
          "Cloud Functions": "compute",
          "Cloud Run": "compute",
          "App Engine": "compute",
          "Cloud IoT Core": "iot"
        }
      }
    }
  ],
  "authentication": {
    "required": true,
    "methods": [
      "gcp_sa"
    ],
    "fields": [
      {
        "name": "project_id",
        "label": "GCP Project ID",
        "type": "string",
        "required": true,
        "sensitive": false,
        "description": "Google Cloud Platform project ID"
      },
      {
        "name": "service_account_key",
        "label": "Service Account Key (JSON)",
        "type": "text",
        "required": true,
        "sensitive": true,
        "description": "JSON content of the service account key file. The service account should have the following permissions: compute.instances.list, compute.zones.list, sqladmin.instances.list, storage.buckets.list, container.clusters.list, cloudfunctions.functions.list"
      }
    ]
  },
  "capabilities": {
    "discovery": true,
    "sync": false,
    "real_time": false,
    "incremental": false
  },
  "rate_limits": {
    "requests_per_second": 10,
    "requests_per_minute": 500,
    "requests_per_hour": 10000
  },
  "supported_operations": [
    "discover_compute_instances",
    "discover_cloud_sql",
    "discover_storage_buckets",
    "discover_gke_clusters",
    "discover_cloud_functions",
    "sync_costs"
  ],
  "default_schedule": "0 */6 * * *",
  "tags": [
    "cloud",
    "gcp",
    "google-cloud",
    "infrastructure",
    "compute",
    "storage",
    "database",
    "kubernetes",
    "serverless",
    "financial",
    "cost-management",
    "finops"
  ]
}
