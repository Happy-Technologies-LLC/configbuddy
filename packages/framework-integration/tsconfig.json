{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "noImplicitReturns": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"],
  "references": [
    { "path": "../common" },
    { "path": "../database" },
    { "path": "../unified-model" },
    { "path": "../event-streaming" },
    { "path": "../itil-service-manager" },
    { "path": "../tbm-cost-engine" }
  ]
}
